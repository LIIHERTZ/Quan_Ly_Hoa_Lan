{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "[YOUR_DEVELOPMENT_DATABASE_CONNECTION_STRING]"
  },
  "JwtSettings": {
    "Secret": "[YOUR_DEVELOPMENT_JWT_SECRET_AT_LEAST_32_CHARACTERS]"
  },
  "Authentication": {
    "Google": {
      "ClientId": "[YOUR_GOOGLE_CLIENT_ID]"
    }
  },
  "Cloudinary": {
    "CloudName": "[YOUR_CLOUDINARY_CLOUD_NAME]",
    "ApiKey": "[YOUR_CLOUDINARY_API_KEY]",
    "ApiSecret": "[YOUR_CLOUDINARY_API_SECRET]"
  }
}
